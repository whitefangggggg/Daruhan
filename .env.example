# Backend API (Supabase project — managed in separate repo)
# Optional for local UI preview: the app runs without these (see DevBackendBanner).
# Required for login, bookings, and admin data.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: static QR PH merchant image URL (used when payment_methods.qr_image_url is empty)
# VITE_PAYMENT_QR_URL=https://your-cdn/daruhan-qrph.png

# Optional: canonical site URL (OAuth uses window.location.origin in the browser)
# VITE_SITE_URL=https://your-domain.netlify.app
